{
  "name": "easy-performance",
  "version": "1.0.6",
  "description": "A visualization dashboard for easy-performance monitor",
  "keywords": [
    "performance",
    "dashboard",
    "visualization",
    "monitor",
    "react",
    "charts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/easy-performance.umd.js",
  "module": "./dist/easy-performance.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/easy-performance.es.js",
      "require": "./dist/easy-performance.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@monitor/sdk": "workspace:*",
    "less": "^4.5.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haodali4s/easy-performance.git"
  },
  "bugs": {
    "url": "https://github.com/haodali4s/easy-performance/issues"
  },
  "homepage": "https://github.com/haodali4s/easy-performance#readme"
}
